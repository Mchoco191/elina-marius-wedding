rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Tout le monde peut lire (pour le classement)
      allow read: if true;
      // Seulement l'utilisateur connecté peut modifier son profil
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
